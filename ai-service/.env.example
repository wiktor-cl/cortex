# Copy to .env to override defaults locally. None of these are required to run the system.
DATABASE_URL=postgresql+asyncpg://cortex:cortex@localhost:5432/cortex

# Optional - unset means the system runs in fully local "extractive" mode (no LLM call, no key needed).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RERANKER_ENABLED=true

CHUNK_SIZE_CHARS=1000
CHUNK_OVERLAP_CHARS=150

LOG_LEVEL=INFO
